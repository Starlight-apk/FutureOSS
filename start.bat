call :section "дҫқиө–е®үиЈ…"

if not exist ".venv" (
    call :color_echo "" "CYAN" "" [i] еҲӣе»әиҷҡжӢҹзҺҜеўғ...
    %PYTHON_CMD% -m venv .venv
)

set "VENV_PYTHON=.venv\Scripts\python.exe"
set "VENV_PIP=.venv\Scripts\pip.exe"

if exist "pyproject.toml" (
    call :color_echo "" "CYAN" "" [i] е®үиЈ…йЎ№зӣ®дҫқиө–...
    %VENV_PIP% install -e . -q 2>nul
)

if exist "requirements.txt" (
    call :color_echo "" "CYAN" "" [i] е®үиЈ… requirements.txt...
    %VENV_PIP% install -r requirements.txt -q 2>nul
)

:: ж ёеҝғдҫқиө–е…ңеә•
for %%p in (click pyyaml websockets) do (
    %VENV_PYTHON% -c "import %%p" 2>nul || (
        call :color_echo "" "CYAN" "" [i] е®үиЈ… %%p ...
        %VENV_PIP% install %%p -q 2>nul
    )
)

