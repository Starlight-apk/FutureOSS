::  1. жЈҖжөӢ Python
:: в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
call :colorEcho 0B "[дҝЎжҒҜ] жЈҖжөӢ Python..."

set "PYTHON_CMD="
for %%p in (python python3 py py3) do (
    where %%p >nul 2>&1
    if !errorlevel! equ 0 (
        set "PYTHON_CMD=%%p"
        goto :found_python
    )
)

:found_python
if "%PYTHON_CMD%"=="" (
    call :colorEcho 0C "[й”ҷиҜҜ] жңӘжүҫеҲ° PythonпјҢиҜ·е…Ҳе®үиЈ… Python 3.10+"
    call :colorEcho 0E "[жҸҗзӨә] дёӢиҪҪең°еқҖ: https://www.python.org/downloads/"
    pause
    exit /b 1
)

for /f "tokens=*" %%i in ('%PYTHON_CMD% --version 2^>^&1') do set "PY_VER=%%i"
call :colorEcho 0A "[жҲҗеҠҹ] %PY_VER%"

:: в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
::  2. иҷҡжӢҹзҺҜеўғ
:: в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
echo.
call :colorEcho 0B "[дҝЎжҒҜ] й…ҚзҪ® Python зҺҜеўғ..."

if not exist ".venv" (
    call :colorEcho 0E "[дҝЎжҒҜ] еҲӣе»әиҷҡжӢҹзҺҜеўғ..."
    %PYTHON_CMD% -m venv .venv >nul 2>&1
    if errorlevel 1 (
        call :colorEcho 0C "[й”ҷиҜҜ] ж— жі•еҲӣе»әиҷҡжӢҹзҺҜеўғ"
        pause
        exit /b 1
    )
    call :colorEcho 0A "[жҲҗеҠҹ] иҷҡжӢҹзҺҜеўғе·ІеҲӣе»ә"
) else (
    call :colorEcho 0A "[жҲҗеҠҹ] иҷҡжӢҹзҺҜеўғе·ІеӯҳеңЁ"
)

call .venv\Scripts\activate.bat >nul 2>&1

:: в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
::  3. е®үиЈ…дҫқиө–
:: в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
echo.
call :colorEcho 0B "[дҝЎжҒҜ] е®үиЈ… Python дҫқиө–..."

set "DEPS=click pyyaml websockets psutil cryptography"
set "TOTAL=5"
set "CURRENT=0"

for %%d in (%DEPS%) do (
    set /a CURRENT+=1
    call :printProgress !CURRENT! !TOTAL! "е®үиЈ… %%d"
    
    %PYTHON_CMD% -c "import %%d" 2>nul
    if errorlevel 1 (
        pip install %%d -q 2>nul
    )
)

echo.
echo.
call :colorEcho 0A "[жҲҗеҠҹ] Python дҫқиө–е®үиЈ…е®ҢжҲҗ"

:: е®үиЈ…йЎ№зӣ®дҫқиө–
if exist "pyproject.toml" (
    call :colorEcho 0E "[дҝЎжҒҜ] е®үиЈ…йЎ№зӣ®й…ҚзҪ®дҫқиө–..."
    pip install -e . -q 2>nul
)

if exist "requirements.txt" (
    call :colorEcho 0E "[дҝЎжҒҜ] е®үиЈ… requirements.txt..."
    pip install -r requirements.txt -q 2>nul
)

:: в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
::  4. жЈҖжҹҘ PHP
:: в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
echo.
call :colorEcho 0B "[дҝЎжҒҜ] жЈҖжҹҘ PHP..."

where php >nul 2>&1
if errorlevel 1 (
    call :colorEcho 0E "[иӯҰе‘Ҡ] PHP жңӘе®үиЈ…пјҢWebUI еҸҜиғҪж— жі•жӯЈеёёе·ҘдҪң"
    call :colorEcho 07 "[жҸҗзӨә] е®үиЈ…: choco install php жҲ–д»Һ https://windows.php.net/download/ дёӢиҪҪ"
) else (
    for /f "tokens=*" %%i in ('php --version 2^>^&1 ^| findstr /r "PHP"') do set "PHP_VER=%%i"
    call :colorEcho 0A "[жҲҗеҠҹ] !PHP_VER!"
)

:: в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
::  5. еҲӣе»әж•°жҚ®зӣ®еҪ•
:: в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
echo.
call :colorEcho 0B "[дҝЎжҒҜ] еҲқе§ӢеҢ–ж•°жҚ®зӣ®еҪ•..."

set "DIRS=data data\html-render data\web-toolkit data\plugin-storage data\DCIM data\pkg data\signature-verifier\keys\private data\signature-verifier\keys\public logs"

for %%d in (%DIRS%) do (
    if not exist "%%d" mkdir "%%d"
)

call :colorEcho 0A "[жҲҗеҠҹ] ж•°жҚ®зӣ®еҪ•е·Іе°ұз»Ә"

:: в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
::  6. еҗҜеҠЁжңҚеҠЎ
:: в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
echo.
call :colorEcho 0B "в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ"
call :colorEcho 0B "  еҗҜеҠЁ FutureOSS"
call :colorEcho 0B "в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ"
echo.

if "%1"=="--daemon" goto :daemon_mode
if "%1"=="-d" goto :daemon_mode

:: еүҚеҸ°жЁЎејҸ
call :colorEcho 0F "иҝҗиЎҢдёӯ... жҢү Ctrl+C еҒңжӯў"
echo.

set "RESTART_DELAY=3"
set "RESTART_COUNT=0"

:loop
%PYTHON_CMD% -m oss.cli serve
set "EXIT_CODE=%errorlevel%"

if %EXIT_CODE% equ 0 (
    call :colorEcho 0A "[жҲҗеҠҹ] жңҚеҠЎжӯЈеёёйҖҖеҮә"
    goto :end
)

set /a RESTART_COUNT+=1
call :colorEcho 0E "[иӯҰе‘Ҡ] жңҚеҠЎејӮеёёйҖҖеҮә (code: %EXIT_CODE%)пјҢ!RESTART_DELAY!s еҗҺйҮҚеҗҜ... (з¬¬ !RESTART_COUNT! ж¬Ў)"
timeout /t !RESTART_DELAY! /nobreak >nul

:: жҢҮж•°йҖҖйҒҝ
if !RESTART_DELAY! lss 30 (
    set /a RESTART_DELAY=!RESTART_DELAY! * 2
)

goto :loop

:daemon_mode
call :colorEcho 0E "[иӯҰе‘Ҡ] Windows е®ҲжҠӨжЁЎејҸйңҖиҰҒйўқеӨ–й…ҚзҪ®"
call :colorEcho 07 "[жҸҗзӨә] е»әи®®дҪҝз”Ёд»»еҠЎи®ЎеҲ’зЁӢеәҸжҲ– nssm е·Ҙе…·е®һзҺ°"
echo.
%PYTHON_CMD% -m oss.cli serve
goto :end

:end
call .venv\Scripts\deactivate.bat >nul 2>&1
pause
exit /b 0

:: в”Җв”Җ иҝӣеәҰжқЎеҮҪж•° в”Җв”Җ
:printProgress
set /a "pct=%1 * 100 / %2"
set /a "filled=pct / 2"
set /a "empty=50-filled"
set "bar="
for /l %%i in (1,1,%filled%) do set "bar=!bar!в–Ҳ"
for /l %%i in (1,1,%empty%) do set "bar=!bar!в–‘"
echo   [!bar!] !pct!%% - %3
exit /b 0

:: в”Җв”Җ йўңиүІиҫ“еҮәеҮҪж•° в”Җв”Җ
:colorEcho
set "params=%1"
set "msg=%~2"
call :colorText %params% "%msg%"
exit /b 0

:colorText
echo %~2
exit /b 0