{
  "metadata": {
    "name": "plugin-bridge",
    "version": "1.1.0",
    "author": "NebulaShell",
    "description": "插件桥接器 - 共享事件/广播/桥接/多语言支持",
    "type": "core",
    "load_priority": "first"
  },
  "config": {
    "enabled": true,
    "args": {
      "max_events": 1000,
      "event_ttl": 3600,
      "broadcast_enabled": true,
      "queue_size": 5000
    }
  },
  "dependencies": ["plugin-storage", "i18n"],
  "permissions": ["plugin-storage", "lifecycle"]
}
