{
  "metadata": {
    "name": "ws-api",
    "version": "1.1.0",
    "author": "FutureOSS",
    "description": "WebSocket API 服务 - 实时双向通信/多语言支持/安全认证",
    "type": "protocol"
  },
  "config": {
    "enabled": true,
    "args": {
      "host": "0.0.0.0",
      "port": 8081,
      "ssl_enabled": false,
      "heartbeat_interval": 30,
      "max_connections": 1000,
      "auth_enabled": true
    }
  },
  "dependencies": ["i18n"],
  "permissions": ["lifecycle"]
}
