{
  "metadata": {
    "name": "signature-verifier",
    "version": "1.0.0",
    "author": "FutureOSS",
    "description": "插件签名验证服务 - 验证官方插件完整性与来源真实性",
    "type": "core"
  },
  "config": {
    "enabled": true,
    "args": {
      "enforce_official": true,
      "key_dir": "data/signature-verifier/keys"
    }
  },
  "dependencies": ["plugin-storage"],
  "permissions": ["plugin-storage"]
}
