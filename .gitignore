```gitignore
# Dependencies
__pycache__/
*.pyc
*.pyo
*.pyd

# Environment
.env
.env.local
*.env.*

# Logs and temporary files
*.log
*.tmp
*.swp

# Coverage reports
coverage/
htmlcov/
.coverage

# IDE specific
.vscode/
.idea/
*.swp
*.swo

# Build artifacts
dist/
build/
*.egg-info/

# OS generated files
.DS_Store
Thumbs.db

# MyPy cache
.mypy_cache/
# Pytest cache
.pytest_cache/
```